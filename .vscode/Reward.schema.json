{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/Agroqirax/TimberbornCycleRewards/refs/heads/master/.vscode/Reward.schema.json",
  "title": "Reward pool schema",
  "description": "List of rewards",
  "type": "object",
  "properties": {
    "FactionRewardSpec": {
      "type": "object",
      "title": "Faction reward spec",
      "properties": {
        "FactionId": {
          "type": "string",
          "title": "Faction Id",
          "description": "FactionId for this reward pool",
          "examples": ["Folktails", "IronTeeth", "Emberpelts"]
        },
        "Rewards": {
          "type": "array",
          "uniqueItems": true,
          "title": "Rewards",
          "description": "Reward pool",
          "minItems": 3,
          "items": {
            "required": ["Type", "Weight"],
            "allOf": [
              {
                "if": {
                  "required": ["Type"],
                  "properties": {
                    "Type": { "const": "Science" }
                  }
                },
                "then": {
                  "required": ["Amount"],
                  "properties": {
                    "Amount": { "type": "integer" }
                  },
                  "title": "Science reward",
                  "description": "Change the amount of science points"
                }
              },
              {
                "if": {
                  "required": ["Type"],
                  "properties": { "Type": { "const": "Resource" } }
                },
                "then": {
                  "required": ["GoodId", "Amount"],
                  "properties": {
                    "Amount": { "type": "integer", "minimum": 0 }
                  },
                  "title": "Resource reward",
                  "description": "Give a certain amount of a resource"
                }
              },
              {
                "if": {
                  "required": ["Type"],
                  "properties": { "Type": { "const": "Weather" } }
                },
                "then": {
                  "required": ["Season", "Amount"],
                  "properties": {
                    "Amount": { "type": "integer" }
                  },
                  "title": "Weather reward",
                  "description": "Change the length of a season\nSeasons cannot become shorter than 1 day"
                }
              },
              {
                "if": {
                  "required": ["Type"],
                  "properties": { "Type": { "const": "Need" } }
                },
                "then": {
                  "required": ["NeedId", "Amount"],
                  "title": "Need reward",
                  "description": "Change how much a specific need is fulfilled for all beavers"
                }
              },
              {
                "if": {
                  "required": ["Type"],
                  "properties": { "Type": { "const": "Building" } }
                },
                "then": {
                  "required": ["BuildingTemplateName"],
                  "title": "Building reward",
                  "description": "Unlock a building"
                }
              },
              {
                "if": {
                  "required": ["Type"],
                  "properties": { "Type": { "const": "Population" } }
                },
                "then": {
                  "required": ["CharacterType", "Amount"],
                  "properties": {
                    "Amount": { "type": "integer" }
                  },
                  "title": "Population reward",
                  "description": "Spawn new characters"
                }
              }
            ],
            "type": "object",
            "properties": {
              "Type": {
                "type": "string",
                "title": "Type",
                "description": "The reward type",
                "enum": [
                  "Science",
                  "Resource",
                  "Weather",
                  "Need",
                  "Building",
                  "Population"
                ]
              },
              "GoodId": {
                "allOf": [{ "$ref": "#/$defs/GoodId" }],
                "description": "The GoodId of the good to give"
              },
              "Amount": {
                "type": "number",
                "title": "Amount",
                "description": "The delta amount to change something by",
                "not": {
                  "const": 0
                }
              },
              "Season": {
                "type": "string",
                "title": "Season",
                "description": "The season to affect",
                "enum": ["Temperate", "Hazardous"]
              },
              "CharacterType": {
                "type": "string",
                "title": "Character type",
                "description": "The CharacterType to spawn",
                "enum": ["Beaver", "Bot", "Child"],
                "default": "Beaver"
              },
              "NeedId": {
                "allOf": [{ "$ref": "#/$defs/NeedId" }],
                "description": "The NeedId of the need to change"
              },
