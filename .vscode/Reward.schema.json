{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "Reward pool schema",
  "type": "object",
  "properties": {
    "FactionRewardSpec": {
      "type": "object",
      "description": "Faction reward spec",
      "properties": {
        "FactionId": {
          "type": "string",
          "description": "FactionId for this reward pool",
          "examples": ["Folktails", "IronTeeth", "Emberpelts"]
        },
        "Rewards": {
          "type": "array",
          "uniqueItems": true,
          "description": "Rewards pool",
          "minItems": 3,
          "items": {
            "required": ["Type", "Weight"],
            "type": "object",
            "title": "Reward",
            "properties": {
              "Type": {
                "type": "string",
                "description": "The reward type",
                "minLength": 1,
                "enum": ["Science", "Resource", "Weather", "Need"]
              },
              "GoodId": {
                "type": "string",
                "description": "The GoodId of the good to give",
                "minLength": 1
              },
              "Amount": {
                "type": "number",
                "description": "The delta amount to change something by\nMust be positive for type: Resource\nMust be int for types: Science, Resource, Weather",
                "not": {
                  "const": 0
                }
              },
              "Season": {
                "type": "string",
                "description": "The season to affect",
                "enum": ["Temperate", "Hazardous"]
              },
              "NeedId": {
                "type": "string",
                "description": "The NeedId of the need to change",
                "minLength": 1
              },
              "Weight": {
                "type": "number",
                "description": "The base weight",
                "minimum": 1
              },
              "WeightCurve": {
                "type": "object",
                "description": "Weight curve",
                "properties": {
                  "Keyframes": {
                    "type": "array",
                    "description": "List of keyframes",
                    "uniqueItems": true,
                    "minItems": 1,
                    "items": {
                      "required": ["Cycle", "Multiplier"],
                      "properties": {
                        "Cycle": {
                          "type": "number",
                          "description": "Cycle number",
                          "minimum": 1
                        },
                        "Multiplier": {
                          "type": "number",
                          "description": "Weight multiplier",
                          "minimum": 0
                        }
                      }
                    }
                  }
                },
                "required": ["Keyframes"]
              }
            },
            "additionalProperties": false
          }
        }
      },
      "required": ["FactionId", "Rewards"]
    }
  },
  "required": ["FactionRewardSpec"]
}
