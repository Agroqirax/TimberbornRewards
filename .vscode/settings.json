{
  "files.exclude": {
    "**/*.meta": true
  },
  "files.associations": {
    "**/*.asmdef": "json"
  },
  "json.schemas": [
    {
      "fileMatch": ["/manifest.json"],
      "url": "https://raw.githubusercontent.com/agroqirax/timberborn-schemas/main/schemas/manifest.schema.json"
    },
    {
      "fileMatch": ["/workshop_data.json"],
      "url": "https://raw.githubusercontent.com/agroqirax/timberborn-schemas/main/schemas/workshop_data.schema.json"
    }
  ]
}
